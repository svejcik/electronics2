# Files for simple dac.
# This dac is standalone with its own power supply
# Currently, two schematics are used:
# bandgap reference and power
#
schematics dac-switches-bits0-3.sch dac-switches-bits4-7.sch dacpower_v1.0.sch r-2r-ladder-v0.0.sch bandgap_reference_v0.2.sch
output-name dac0.project

# After editing schematics. run gsch2pcb
# to generate .net, .pcb, and .new.pcb files
